# Copie para .env e preencha. NÃO comite o .env (está no .gitignore).

# Supabase (chaves publishable — públicas, protegidas por RLS)
SUPABASE_PROJECT_ID="seu-project-id"
SUPABASE_PUBLISHABLE_KEY="sua-publishable-key"
SUPABASE_URL="https://seu-project-id.supabase.co"
VITE_SUPABASE_PROJECT_ID="seu-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-publishable-key"
VITE_SUPABASE_URL="https://seu-project-id.supabase.co"

# IA — Google Gemini (gere em https://aistudio.google.com/apikey)
GEMINI_API_KEY="sua-chave-gemini"
